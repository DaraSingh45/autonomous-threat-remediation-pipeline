    {
      "id": 4,
      "type": "timeseries",
      "title": "Synthetic Events by Type",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus_ds"
      },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(events_produced_total[1m]))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus_ds"
          },
          "refId": "A",
          "legendFormat": "{{event_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
