{
  "id": null,
  "uid": "atrp-mttr-mttd",
  "title": "Autonomous Threat Remediation Pipeline",
  "description": "Detection throughput, threat severity mix, and the MTTD/MTTR before-vs-after-automation comparison.",
  "tags": [
    "soar",
    "security",
    "atrp"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Events Ingested (events/sec)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus_ds"
      },
      "targets": [
        {
          "expr": "sum(rate(events_produced_total[1m]))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus_ds"
          },
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Threats Detected (per sec)",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus_ds"
      },
      "targets": [
        {
          "expr": "sum(rate(threats_detected_total[1m]))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus_ds"
          },
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
